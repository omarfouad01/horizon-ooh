# ─── HORIZON OOH — .gitignore ────────────────────────────────────────────

# --- Dependencies ---
node_modules/
jspm_packages/

# --- Package manager caches / debug logs ---
.npm/
.pnpm-store/
.pnpm-debug.log*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/sdks
!.yarn/versions
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# --- Logs ---
logs/
*.log
report.[0-9]*.json

# --- Env files (keep example templates) ---
.env
.env.*
!.env.example
!.env.*.example

# --- Build outputs ---
dist/
build/
.vite/
*.tsbuildinfo

# --- PHP: NEVER commit real credentials ---
backend/config/config.php
backend/lib/RateLimiter.storage/

# --- Editors / OS ---
.vscode/*
!.vscode/extensions.json
.idea/
*.iml
.DS_Store
Thumbs.db
*.swp

# --- Test / coverage ---
coverage/
.nyc_output/

# --- Supabase (unused in PHP setup) ---
supabase/.branches
supabase/.temp

public/app/*
vendor/
