# Apache configuration for HORIZON OOH Frontend (React SPA)
# Place this file at the web root where index.html is served from.

Options -Indexes

<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteBase /

    # Serve existing files and directories directly
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d

    # Proxy /api/* to the PHP backend folder
    RewriteRule ^api/(.*)$ backend/api/index.php [QSA,L]

    # All other routes → React SPA entry point
    RewriteRule ^ index.html [QSA,L]
</IfModule>

<IfModule mod_headers.c>
    # Cache static assets aggressively
    <FilesMatch "\.(js|css|png|jpg|jpeg|gif|ico|svg|woff2|woff|ttf|eot)$">
        Header set Cache-Control "public, max-age=31536000, immutable"
    </FilesMatch>
    # Never cache HTML
    <FilesMatch "\.html$">
        Header set Cache-Control "no-cache, no-store, must-revalidate"
    </FilesMatch>
    # Security
    Header always set X-Content-Type-Options "nosniff"
    Header always set X-Frame-Options        "SAMEORIGIN"
</IfModule>
