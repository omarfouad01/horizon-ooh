RewriteEngine On

# 1. If it's a physical file or directory in /public, serve it
RewriteCond %{DOCUMENT_ROOT}/public%{REQUEST_URI} -f [OR]
RewriteCond %{DOCUMENT_ROOT}/public%{REQUEST_URI} -d
RewriteRule ^(.*)$ public/$1 [L]

# 2. Redirect API or backend routes to Laravel's index.php
# Add any other prefixes you use for Laravel here (e.g., storage, admin)
RewriteCond %{REQUEST_URI} ^/(api|storage|telescope) [NC]
RewriteRule ^(.*)$ public/index.php [QSA,L]

# 3. Everything else goes to your React index.html
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^ /public/index.html [L]

# php -- BEGIN cPanel-generated handler, do not edit
# Set the “ea-php83” package as the default “PHP” programming language.
<IfModule mime_module>
  AddHandler application/x-httpd-ea-php83 .php .php8 .phtml
</IfModule>
