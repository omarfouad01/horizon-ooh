##########################################################################
# HORIZON OOH — Laravel Backend Environment Configuration
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
##########################################################################

# ── Application ──────────────────────────────────────────────────────────────
APP_NAME="HORIZON OOH"
APP_ENV=production          # local | testing | production
APP_KEY=                    # Run: php artisan key:generate
APP_DEBUG=false             # Set to true ONLY in local dev
APP_URL=https://your-domain.com

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
BCRYPT_ROUNDS=12

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=error             # debug | info | warning | error  (use error in production)

# ── Database (MySQL) ──────────────────────────────────────────────────────────
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=horizon_ooh
DB_USERNAME=your_db_user
DB_PASSWORD=your_db_password
DB_CHARSET=utf8mb4
DB_COLLATION=utf8mb4_unicode_ci

# ── Session / Cache / Queue ───────────────────────────────────────────────────
SESSION_DRIVER=file         # file | database | redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

CACHE_STORE=file            # file | redis | database
QUEUE_CONNECTION=sync       # sync (no worker needed) | database | redis

# ── Broadcasting ─────────────────────────────────────────────────────────────
BROADCAST_CONNECTION=log

# ── File Storage ─────────────────────────────────────────────────────────────
FILESYSTEM_DISK=public      # Billboard images stored in storage/app/public
# Run after deployment: php artisan storage:link

# ── JWT Authentication ────────────────────────────────────────────────────────
JWT_SECRET=                 # Run: php artisan jwt:secret
JWT_TTL=1440                # Token lifetime in minutes (default 24 hours)
JWT_REFRESH_TTL=20160       # Refresh TTL in minutes (default 2 weeks)
JWT_ALGO=HS256

# ── Mail (SMTP) ───────────────────────────────────────────────────────────────
MAIL_MAILER=smtp
MAIL_SCHEME=tls             # tls (port 587) | ssl (port 465)
MAIL_HOST=smtp.example.com  # e.g. smtp.gmail.com / mail.your-host.com
MAIL_PORT=587
MAIL_USERNAME=your@email.com
MAIL_PASSWORD=your_smtp_password
MAIL_FROM_ADDRESS=info@horizonooh.com
MAIL_FROM_NAME="HORIZON OOH"
MAIL_ADMIN_EMAIL=admin@horizonooh.com  # Where contact form notifications go

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins.
# In production, restrict to your actual domain(s):
# CORS_ALLOWED_ORIGINS=https://horizonooh.com,https://www.horizonooh.com
CORS_ALLOWED_ORIGINS=*

# ── Redis (optional – faster cache/queue/session) ─────────────────────────────
# REDIS_CLIENT=phpredis
# REDIS_HOST=127.0.0.1
# REDIS_PASSWORD=null
# REDIS_PORT=6379

# ── AWS S3 (optional – cloud image storage) ──────────────────────────────────
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_DEFAULT_REGION=eu-central-1
# AWS_BUCKET=horizonooh-media
# FILESYSTEM_DISK=s3          # Switch to s3 if using S3
