# ─── HORIZON OOH — Frontend Environment Variables ────────────────────────────
# Copy this file to .env and fill in your values.
#   cp .env.example .env
# NEVER commit .env to Git — it is already in .gitignore.
# ─────────────────────────────────────────────────────────────────────────────


# ── API ───────────────────────────────────────────────────────────────────────
# Full URL to the PHP backend API (no trailing slash).
#
# Development (Vite dev-server proxy):
#   VITE_API_URL=http://localhost:8000/api
#
# Production (same domain — Apache proxies /api → backend/api/index.php):
#   VITE_API_URL=/api
#
# Production (separate subdomain / server):
#   VITE_API_URL=https://api.horizonooh.com/api
#
VITE_API_URL=http://localhost:8000/api


# ── Route Messaging ───────────────────────────────────────────────────────────
# Controls whether the app posts route-change messages to a parent iframe.
# Used by the Skywork editor to track navigation.
#
# Set to "false" in every production deployment to eliminate the overhead.
# Set to "true" (or omit) only when running inside the Skywork editor iframe.
#
VITE_ENABLE_ROUTE_MESSAGING=false


# ── App Environment (passed to Vite at build time if needed) ──────────────────
# Optional — kept for parity with the PHP backend config.
# Vite uses NODE_ENV internally; this is a convenience reference only.
#
# VITE_APP_ENV=production
