# ─── HORIZON OOH — Environment Variables ─────────────────────────────────
# Copy this file to .env and fill in your values.
# The .env file is in .gitignore and must NEVER be committed.

# ── Application ──────────────────────────────────────────────────────────
APP_ENV=production
APP_URL=https://horizonooh.com

# ── CORS — set to your frontend domain ───────────────────────────────────
CORS_ORIGIN=https://horizonooh.com

# ── Database (MySQL / MariaDB) ────────────────────────────────────────────
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=horizonooh
DB_USER=horizonooh_user
DB_PASS=your_secure_password_here

# ── Mail (SMTP) ───────────────────────────────────────────────────────────
MAIL_DRIVER=smtp
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_ENCRYPTION=tls
MAIL_USERNAME=your@gmail.com
MAIL_PASSWORD=your_app_password_here
MAIL_FROM_EMAIL=info@horizonooh.com
MAIL_FROM_NAME=HORIZON OOH
MAIL_TO_EMAIL=info@horizonooh.com

# ── API ───────────────────────────────────────────────────────────────────
API_SECRET_KEY=replace-with-a-long-random-string

# ── Vite (Frontend) ───────────────────────────────────────────────────────
# URL of the PHP API — used by the React frontend in production.
VITE_API_URL=https://horizonooh.com/api
